# Required: API + DB
# Supabase Postgres example:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
CONTEXT_TOKEN_SECRET=

# Required: real generation provider
MESHY_API_KEY=

# Required: Supabase storage
SUPABASE_URL=
# Server-side only. Never expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=assets

# Optional: planner call from API to local Fetch agent
FETCH_AGENT_PLAN_URL=http://127.0.0.1:8001/plan

# Optional: only if you run agent_service/main.py
FETCH_AGENT_SEED=
